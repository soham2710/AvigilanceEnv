# Avigilance 2.0 — Environment Variables
# Copy this file to .env and fill in your values before running inference.py.
# Do not commit .env to version control.

# --- REQUIRED (hackathon evaluation uses exactly these three variables) ---

# Base URL for the OpenAI API.
API_BASE_URL=https://api.openai.com/v1

# Model identifier for the OpenAI API.
MODEL_NAME=gpt-4o-mini

# Primary credential variable. If you prefer, you can instead set OPENAI_API_KEY below.
HF_TOKEN=your_api_key_here

# Optional explicit OpenAI credential. If set, it takes priority over HF_TOKEN.
OPENAI_API_KEY=sk-proj-...
