# Avigilance 2.0 — Environment Variables
# Copy this file to .env and fill in your values before running inference.py.
# Do not commit .env to version control.

# Base URL for the OpenAI-compatible LLM API.
# OpenRouter (recommended — free models + auto-fallback): https://openrouter.ai/api/v1
# HuggingFace Inference Router:                           https://router.huggingface.co/v1
# OpenAI:                                                 https://api.openai.com/v1
API_BASE_URL=https://openrouter.ai/api/v1

# Model to use. With OpenRouter you can set this to:
#   openrouter/free          — smart router across ALL free models (recommended)
#   google/gemma-3-27b-it:free
#   meta-llama/llama-3.2-3b-instruct:free
#   google/gemma-3-12b-it:free
# inference.py and evaluate_agent.py rotate through a full fallback pool
# automatically if any individual model hits rate limits.
MODEL_NAME=openrouter/free

# OpenRouter API key (get one free at openrouter.ai)
OPEN_ROUTER_API=sk-or-v1-...

# HuggingFace token — used when API_BASE_URL points to router.huggingface.co
# Also used as fallback API key if OPEN_ROUTER_API is not set.
HF_TOKEN=hf_...
