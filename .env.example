# Avigilance 2.0 — Environment Variables
# Copy this file to .env and fill in your values before running inference.py.
# Do not commit .env to version control.

# --- REQUIRED (hackathon evaluation uses exactly these three variables) ---

# Base URL for the OpenAI-compatible LLM API.
# OpenAI:                           https://api.openai.com/v1
# HuggingFace Inference Router:     https://router.huggingface.co/v1
# OpenRouter:                       https://openrouter.ai/api/v1
API_BASE_URL=https://api.openai.com/v1

# Model identifier for the chosen provider.
MODEL_NAME=gpt-4o-mini

# API key — used as the universal credential.
# For OpenAI: your sk-proj-... key
# For HuggingFace: your hf_... token
# For OpenRouter: your sk-or-... key
HF_TOKEN=your_api_key_here

# --- OPTIONAL local-dev overrides ---
# If set, takes priority over HF_TOKEN when using the OpenAI endpoint.
OPENAI_API_KEY=sk-proj-...

# If set, takes priority when using the OpenRouter endpoint.
OPEN_ROUTER_API=sk-or-v1-...
